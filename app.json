{
  "expo": {
    "name": "Chessling",
    "slug": "chessling",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Chess_Icon_no_bg.png",
    "scheme": "chessling",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.wallet-ui.expo-kit"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0F",
        "foregroundImage": "./assets/images/Chess_Icon_no_bg.png",
        "backgroundImage": "./assets/images/Chess_Icon_no_bg.png",
        "monochromeImage": "./assets/images/Chess_Icon_no_bg.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "dev.wallet_ui.expo_kit"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "resizeMode": "contain",
          "backgroundColor": "#0B0B0F",
          "dark": {
            "backgroundColor": "#0B0B0F"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}